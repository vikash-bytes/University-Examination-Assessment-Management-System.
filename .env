# =====================================
# API CONFIGURATION
# =====================================

REACT_APP_API_URL=http://localhost:5000
REACT_APP_TIMEOUT=30000

# =====================================
# APP CONFIGURATION
# =====================================

REACT_APP_APP_NAME=University Exam System
REACT_APP_VERSION=1.0.0

# =====================================
# AUTH CONFIGURATION
# =====================================

REACT_APP_TOKEN_KEY=authToken
